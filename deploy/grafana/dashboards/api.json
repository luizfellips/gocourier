{
  "uid": "api-dashboard",
  "title": "API",
  "tags": ["phase-b", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(api_requests_total[1m]))", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "5xx rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "sum(rate(api_requests_total{status=~\"5..\"}[1m]))", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "p95 latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(api_request_duration_seconds_bucket[5m])) by (le))", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "Notifications received",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "sum(rate(notifications_received_total[1m])) by (channel)", "refId": "A"}]
    }
  ]
}
