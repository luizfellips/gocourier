SERVICE_NAME=gocourier
LOG_LEVEL=info
HTTP_ADDR=:8080
API_KEYS=dev-api-key

DATABASE_URL=postgres://gocourier:gocourier@localhost:5432/gocourier?sslmode=disable
NATS_URL=nats://localhost:4222
NATS_STREAM_PREFIX=notifications
NATS_MAX_DELIVER=8
NATS_ACK_WAIT=30s

OUTBOX_POLL_INTERVAL=500ms
OUTBOX_BATCH_SIZE=50
SCHEDULER_POLL_INTERVAL=5s

WORKER_CONCURRENCY=10
WORKER_CHANNELS=email,sms,push,webhook

MAX_RETRY_ATTEMPTS=8
RETRY_BASE_DELAY=1s
RETRY_MAX_DELAY=30m
IDEMPOTENCY_TTL=24h

CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_WINDOW=60s
CIRCUIT_BREAKER_COOLDOWN=30s

# Observability (Phase B)
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
OTEL_SERVICE_NAME=api
OTEL_TRACES_SAMPLER=parentbased_always_on
METRICS_ADDR=:9090
